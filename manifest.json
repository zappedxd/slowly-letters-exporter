{
  "manifest_version": 3,
  "name": "Slowly Letter Exporter",
  "version": "1.0.0",
  "description": "Export Slowly web letters as HTML ZIP, DOCX, TXT, PDF, or Markdown.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["https://*.slowly.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.slowly.app/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}