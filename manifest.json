{
  "manifest_version": 3,
  "name": "Slowly Letter Exporter",
  "version": "1.0.0",
  "description": "Export Slowly web letters as DOCX, TXT, or Markdown.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["https://*.slowly.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Slowly Letter Exporter"
  },
  "content_scripts": [
    {
      "matches": ["https://*.slowly.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
