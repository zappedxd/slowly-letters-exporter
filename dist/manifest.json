{
  "manifest_version": 3,
  "name": "Slowly Letter Exporter",
  "version": "1.0.0",
  "description": "Export Slowly web letters as HTML ZIP, DOCX, TXT, PDF, or Markdown.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://*.slowly.app/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-DsNOXg4K.js"
      ],
      "matches": [
        "https://*.slowly.app/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.slowly.app/*"
      ],
      "resources": [
        "assets/content.js-DsNOXg4K.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
